# .env.local — copy this file, rename to .env.local, fill in your values
# NEVER commit .env.local to GitHub

# ── SUPABASE ────────────────────────────────────────────────────────────────
# From: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyYOUR-ANON-KEY

# ── STRIPE ──────────────────────────────────────────────────────────────────
# From: https://dashboard.stripe.com/apikeys (Secret key — starts with sk_live_)
STRIPE_SECRET_KEY=sk_live_YOUR-SECRET-KEY

# ── SUPABASE SERVICE ROLE (for Vercel API function only) ────────────────────
# From: Supabase Dashboard → Settings → API → service_role key
# This key bypasses RLS — only used server-side in api/verify-payment.js
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyYOUR-SERVICE-ROLE-KEY
